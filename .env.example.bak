# Firebase Configuration
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Faspay Payment Gateway
VITE_FASPAY_MERCHANT_ID=your_merchant_id
VITE_FASPAY_MERCHANT_NAME=your_merchant_name
VITE_FASPAY_USER_ID=your_user_id
VITE_FASPAY_PASSWORD=your_password
VITE_FASPAY_API_URL=https://web.faspay.co.id

# OpenAI / AI Chat
VITE_OPENAI_API_KEY=your_openai_api_key

# App Configuration
VITE_APP_NAME=FahriXz Store
VITE_APP_URL=https://fahrixzstore.com
VITE_API_BASE_URL=/api

# Environment
NODE_ENV=production
